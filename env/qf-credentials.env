# QualityFlow agent credentials.
# Sourced inside the sandbox via host_files (expand: true).
#
# Vertex AI credentials are in gcp-vertex.env (shared with other agents).

# Jira — used by stp-builder, stp-reviewer, stp-refiner for ticket data.
export JIRA_BASE_URL=${JIRA_BASE_URL}
export JIRA_API_TOKEN=${JIRA_API_TOKEN}
export JIRA_USER_EMAIL=${JIRA_USER_EMAIL}
export JIRA_TICKET=${JIRA_TICKET}

# QualityFlow config directory — set by agent_input in the harness.
# The config/ directory is SCP'd into /tmp/workspace/agent-input/ by fullsend.
export QF_CONFIG_DIR=/tmp/workspace/agent-input

# Source code repository for LSP analysis.
# Mounted via host_files from $SOURCE_REPO_PATH on the host.
# If not mounted, LSP gracefully degrades to the pattern library.
export SOURCE_REPO_DIR=/tmp/workspace/source-repo

# GitHub — read-only access for PR diffs and repo_files fetch.
export GH_TOKEN=${GH_TOKEN}
export GITHUB_TOKEN=${GH_TOKEN}

# SSL certs — OpenShell does TLS termination and injects its own CA bundle.
# git and curl need this to trust the proxy's certificate.
if [ -f /etc/openshell-tls/ca-bundle.pem ]; then
  export GIT_SSL_CAINFO=/etc/openshell-tls/ca-bundle.pem
  export CURL_CA_BUNDLE=/etc/openshell-tls/ca-bundle.pem
else
  export GIT_SSL_CAINFO=/etc/ssl/certs/ca-certificates.crt
fi
