{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "std-refiner-result.schema.json",
  "title": "STD Refiner Result",
  "description": "Structured output from the QualityFlow STD refiner agent. Validated by the harness before the post-script runs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "jira_id"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "jira_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]+-\\d+$"
    },
    "verdict": {
      "type": "string",
      "enum": ["APPROVED", "APPROVED_WITH_FINDINGS", "NEEDS_REVISION"]
    },
    "iterations": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of review-refine iterations performed"
    },
    "weighted_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "refined_std": {
      "type": "string",
      "description": "Path to the refined STD YAML"
    },
    "refinement_log": {
      "type": "string",
      "description": "Path to the refinement log markdown"
    },
    "reason": {
      "type": "string",
      "enum": ["std-not-found", "review-not-found", "config-error", "timeout", "max-iterations-reached"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "success" } }, "required": ["status"] },
      "then": { "required": ["verdict", "iterations", "refined_std"] }
    },
    {
      "if": { "properties": { "status": { "const": "error" } }, "required": ["status"] },
      "then": { "required": ["reason"] }
    }
  ]
}
