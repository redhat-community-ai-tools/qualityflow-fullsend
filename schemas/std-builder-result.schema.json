{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "std-builder-result.schema.json",
  "title": "STD Builder Result",
  "description": "Structured output from the QualityFlow STD builder agent. Validated by the harness before the post-script runs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "jira_id"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "jira_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]+-\\d+$"
    },
    "std_yaml": {
      "type": "string",
      "description": "Path to generated STD YAML file"
    },
    "go_stubs": {
      "type": "string",
      "description": "Path to generated Go stub files directory"
    },
    "python_stubs": {
      "type": "string",
      "description": "Path to generated Python stub files directory"
    },
    "scenarios_implemented": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of test scenarios converted to STD entries"
    },
    "reason": {
      "type": "string",
      "enum": ["stp-not-found", "config-error", "timeout", "invalid-stp"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "success" } }, "required": ["status"] },
      "then": { "required": ["std_yaml"] }
    },
    {
      "if": { "properties": { "status": { "const": "error" } }, "required": ["status"] },
      "then": { "required": ["reason"] }
    }
  ]
}
